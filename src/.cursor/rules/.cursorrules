################################################################################
# project
project:
  name: MagicSquare
  description: "Dual-Track UI와 로직 TDD를 결합해 매직스퀘어 생성·검증 기능을 안정적으로 개발하는 프로젝트"
  methodology: "Dual-Track UI + Logic TDD with MLOps"

################################################################################
# code_style
code_style:
  python_version: "3.10+"
  pep8: "엄격 준수"
  type_hints: "모든 함수 파라미터와 반환 타입에 필수"
  docstring: "Google 스타일로 public 함수/메서드에 필수"
  max_line_length: 88

################################################################################
# architecture
architecture:
  pattern: ECB
  boundary:
    role: "UI, API, CLI 등 외부 입출력 처리와 요청/응답 변환 담당"
  control:
    role: "유스케이스 흐름 제어와 비즈니스 로직 오케스트레이션 담당"
  entity:
    role: "도메인 데이터 모델과 핵심 규칙/불변성 검증 담당"
  dependency_direction:
    - "boundary -> control"
    - "control -> entity"
    - "boundary -> entity 직접 의존 금지"
    - "entity -> control/boundary 의존 금지"

################################################################################
# tdd_rules
tdd_rules:
  red_phase:
    description: "요구사항을 실패하는 테스트로 먼저 명세하는 단계"
    rules:
      - "기능 구현 전 테스트를 먼저 작성한다."
      - "테스트가 실패하는지 실행으로 확인한다."
      - "실패 원인이 요구사항 미구현인지 검증한다."
    must_not:
      - "테스트 없이 프로덕션 코드를 먼저 작성하지 않는다."
      - "한 번에 여러 요구사항을 동시에 구현하지 않는다."
  green_phase:
    description: "테스트를 통과시키는 최소 구현을 작성하는 단계"
    rules:
      - "추가한 테스트를 통과시키는 최소 코드만 작성한다."
      - "변경 후 관련 테스트를 즉시 재실행한다."
      - "기능 요구사항 범위 내에서만 코드를 추가한다."
    must_not:
      - "성능 최적화나 구조 개선을 선행하지 않는다."
      - "이 단계에서 리팩터링을 수행하지 않는다."
  refactor_phase:
    description: "동작 변경 없이 구조를 개선하는 단계"
    rules:
      - "중복 제거와 가독성 개선을 기능 변경 없이 수행한다."
      - "리팩터링 전후 전체 테스트 통과를 유지한다."
      - "커버리지를 기준 이하로 낮추지 않는다."
    must_not:
      - "새 기능을 추가하거나 기존 동작을 변경하지 않는다."
      - "테스트를 임의로 삭제하거나 약화하지 않는다."

################################################################################
# testing
testing:
  framework: pytest
  pattern: "AAA (Arrange-Act-Assert)"
  coverage_minimum: "80%"
  fixture_rules:
    default_scope: function
    shared_resource_scope: module
    session_scope: "외부 리소스 초기화 비용이 큰 경우에만 제한적으로 사용"
    isolation: "테스트 간 상태 공유 금지"
  naming_convention: "테스트 파일과 함수는 test_ 접두사 필수"

################################################################################
# forbidden
forbidden:
  - pattern: "print() 디버깅"
    reason: "로그 추적 일관성을 깨고 운영 환경에서 노이즈를 유발한다."
    alternative: "logging 모듈의 레벨 기반 로깅을 사용한다."
  - pattern: "하드코딩 상수(매직 넘버/문자열)"
    reason: "유지보수성을 낮추고 규칙 변경 시 누락 위험을 높인다."
    alternative: "상수 모듈, Enum, 설정 파일로 분리한다."
  - pattern: "bare except (except:)"
    reason: "예외 원인을 숨겨 디버깅과 장애 분석을 어렵게 만든다."
    alternative: "명시적 예외 타입을 지정하고 필요 시 재전파한다."
  - pattern: "레이어 경계 우회 호출(boundary -> entity 직접 호출)"
    reason: "아키텍처 일관성을 깨고 비즈니스 규칙 중복을 유발한다."
    alternative: "반드시 control 레이어를 통해 호출한다."
  - pattern: "타입힌트 없는 public 함수"
    reason: "정적 분석 품질 저하와 인터페이스 오해를 유발한다."
    alternative: "모든 파라미터와 반환값에 타입힌트를 명시한다."

################################################################################
# file_structure
file_structure:
  root: src/
  example: |
    src/
      boundary/
        ui/
        api/
        cli/
      control/
        use_cases/
        services/
      entity/
        models/
        rules/
      tests/
        unit/
        integration/

################################################################################
# ai_behavior
ai_behavior:
  before_code_generation:
    - "관련 테스트 파일과 기존 실패 이력을 먼저 확인한다."
    - "변경 대상의 ECB 레이어 소속과 의존성 방향을 점검한다."
    - "추가/수정 함수의 타입힌트와 docstring 요구사항을 사전 확인한다."
  during_code_generation:
    - "ECB 레이어 경계를 위반하는 참조를 만들지 않는다."
    - "타입힌트 없는 함수를 생성하지 않는다."
    - "green_phase에서는 테스트 통과 최소 코드만 작성한다."
  after_code_generation:
    - "pytest로 관련 테스트와 회귀 테스트를 실행한다."
    - "tdd_rules 위반이 감지되면 위반 단계와 사유를 경고한다."
    - "커버리지가 최소 기준 이상인지 확인한다."
